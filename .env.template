# .env.template — Copy to .env.local and fill in values
# DO NOT commit .env.local or .env to Git (both are gitignored).
#
# The wizard generates .env (with 1Password op:// references) or .env.local
# (with encrypted secrets) automatically — you should not need to edit this
# template manually for normal use.

# Power Platform Authentication (Service Principal)
# Get these values from your team lead or 1Password vault
PP_TENANT_ID=
PP_APP_ID=
PP_CLIENT_SECRET=

# Environment URLs
PP_ENV_DEV=https://your-org-dev.crm.dynamics.com
PP_ENV_TEST=https://your-org-test.crm.dynamics.com
PP_ENV_PROD=https://your-org-prod.crm.dynamics.com
