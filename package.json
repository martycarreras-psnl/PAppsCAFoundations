{
  "name": "papps-ca-foundations",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo for the Power Apps Code App Foundations (@pacaf/*) packages.",
  "type": "module",
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "lint": "pnpm -r --if-present run lint",
    "test": "pnpm -r --if-present run test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm publish -r --access public --no-git-checks --filter '@pacaf/*'",
    "rebrand": "node packages/rebrand/bin/pacaf-rebrand.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "node-pty"
    ]
  }
}
